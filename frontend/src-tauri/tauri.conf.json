{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stock Analysis Workstation",
  "version": "0.0.1",
  "identifier": "com.rathore.stockanalysis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stock Analysis Workstation",
        "width": 1600,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
